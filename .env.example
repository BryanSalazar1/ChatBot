# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/chatbot_db?retryWrites=true&w=majority

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Opciones: ollama | openai | anthropic
LLM_PROVIDER=ollama

# ── Ollama (local) ────────────────────────────────────────────────────────────
# Requiere tener Ollama corriendo: https://ollama.com
OLLAMA_MODEL=llama3

# ── OpenAI API (alternativa) ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-3.5-turbo

# ── Anthropic API (alternativa) ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
